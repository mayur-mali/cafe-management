            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Admin\",\n  \"email\": \"admin@gamingcafe.com\",\n  \"password\": \"SecurePass123!@\",\n  \"phone\": \"9876543210\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/register",
